VITE_API_BASE_URL=http://localhost:3020

# Assinatura macOS (build local ou CI): certificado .p12 em base64 e senha; Apple ID para notarização
# MAC_CSC_LINK=<base64 do .p12>
# MAC_CSC_KEY_PASSWORD=<senha do certificado>
# APPLE_ID=<email Apple Developer>
# APPLE_APP_SPECIFIC_PASSWORD=<senha de app>
# APPLE_TEAM_ID=<Team ID>

# Assinatura Windows (build local ou CI): certificado .pfx em base64 e senha
# WIN_CSC_LINK=<base64 do .pfx>
# WIN_CSC_KEY_PASSWORD=<senha do certificado>
